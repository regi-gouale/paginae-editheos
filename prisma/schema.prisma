// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id
  name          String
  email         String
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
  member        Member?        @relation("UserMember")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Member {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  role      MemberRole @default(CONTRIBUTOR)
  slug      String?    @unique
  userId    String?    @unique
  user      User?      @relation("UserMember", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  projects Project[] @relation("ProjectMembers")

  @@map("member")
}

enum MemberRole {
  ADMIN
  DESIGNER
  REVIEWER
  CONTRIBUTOR
  GUEST
}

enum ProjectStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  REJECTED
}

enum RuleConditionType {
  DUE_DATE
  TASKS_COMPLETED
  CUSTOM_FIELD
}

enum RuleConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  IS_EMPTY
  IS_NOT_EMPTY
  IS_OVERDUE
  ALL_COMPLETED
  ANY_COMPLETED
}

enum RuleActionType {
  MOVE_TO_COLUMN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectType {
  EDITION
  PRINTING
}

model Author {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String    @unique
  slug        String?   @unique
  biography   String?
  website     String?
  nationality String?
  birthDate   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  projects Project[] @relation("ProjectAuthors")

  @@map("author")
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String?
  slug        String?       @unique
  status      ProjectStatus @default(TODO)
  dueDate     DateTime?
  priority    Priority      @default(LOW)
  type        ProjectType   @default(EDITION)
  fileUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  authors       Author[]       @relation("ProjectAuthors")
  members       Member[]       @relation("ProjectMembers")
  tasks         ProjectTask[]
  customFields  CustomField[]
  notifications Notification[]
  kanbanColumn  KanbanColumn?  @relation(fields: [columnId], references: [id])
  columnId      String?

  @@map("project")
}

model ProjectTask {
  id        String   @id @default(uuid())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("project_task")
}

model TaskTemplate {
  id          String      @id @default(uuid())
  title       String
  projectType ProjectType
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  @@map("task_template")
}

model CustomField {
  id        String   @id @default(uuid())
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("custom_field")
}

model KanbanColumn {
  id        String   @id @default(uuid())
  title     String
  color     String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  projects Project[]

  @@map("kanban_column")
}

model Rule {
  id        String   @id @default(uuid())
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  condition RuleCondition?
  action    RuleAction?

  @@map("rule")
}

model RuleCondition {
  id       String                @id @default(uuid())
  type     RuleConditionType
  field    String?
  operator RuleConditionOperator
  value    String?

  // Relations
  rule   Rule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId String @unique

  @@map("rule_condition")
}

model RuleAction {
  id             String         @id @default(uuid())
  type           RuleActionType
  targetColumnId String

  // Relations
  rule   Rule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId String @unique

  @@map("rule_action")
}

enum NotificationType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MOVED
  PROJECT_ASSIGNED
  PROJECT_UNASSIGNED
  PROJECT_DUE_SOON
  PROJECT_OVERDUE
  TASK_COMPLETED
  MEMBER_ADDED
  AUTHOR_ADDED
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @default(now()) @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@map("notification")
}
