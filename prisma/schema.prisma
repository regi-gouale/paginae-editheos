// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Member {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  role      MemberRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  projects Project[] @relation("ProjectMembers")

  @@map("member")
}

enum MemberRole {
  ADMIN
  DESIGNER
  REVIEWER
  CONTRIBUTOR
  GUEST
}

model Author {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String    @unique
  biography   String?
  website     String?
  nationality String?
  birthDate   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  projects Project[] @relation("ProjectAuthors")

  @@map("author")
}

model Project {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String
  dueDate     DateTime? @map("endDate")
  priority    Int

  authors Author[] @relation("ProjectAuthors")
  members Member[] @relation("ProjectMembers")
  tasks   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("project")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  priority    Int
  dueDate     DateTime?

  completed   Boolean   @default(false)
  completedAt DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  kanbanColumn   KanbanColumn? @relation("KanbanColumnTasks", fields: [kanbanColumnId], references: [id])
  kanbanColumnId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("task")
}

model CustomField {
  id    String @id @default(uuid())
  name  String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("custom_field")
}

model KanbanColumn {
  id    String  @id @default(uuid())
  name  String
  tasks Task[]  @relation("KanbanColumnTasks")
  color String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("kanban_column")
}

// Add new Rule interfaces for automation
model Rule {
  id          String      @id @default(uuid())
  name        String
  conditionId String
  condition   RuleCondion @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  actionId    String
  action      RuleAction  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  isActive    Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("rule")
}

enum RuleConditionType {
  DUE_DATE
  TASK_COMPLETED
  CUSTOM_FIELD
}

enum RuleConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  IS_EMPTY
  IS_NOT_EMPTY
  IS_OVERDUE
  ALL_COMPLETED
}

enum RuleActionType {
  SEND_NOTIFICATION
  ASSIGN_MEMBER
  MOVE_TASK
  UPDATE_FIELD
  MOVE_TO_COLUMN
}

model RuleCondion {
  id       String                @id @default(uuid())
  type     RuleConditionType
  field    String?
  operator RuleConditionOperator
  value    String?

  rules Rule[]
}

model RuleAction {
  id             String         @id @default(uuid())
  type           RuleActionType
  targetColumnId String

  rules Rule[]
}
